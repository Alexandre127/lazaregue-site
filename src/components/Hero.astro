---
// Section Hero — popup CTA « Parler à un avocat »
---

<section class="laz-hero" id="hero">
  <div class="laz-hero-left">
    <div class="laz-hero-copy">
      <slot name="hero-content" />

      <div class="laz-hero-cta-wrap">
        <div class="laz-cta-row hero-cta-anchor">
          <button
            type="button"
            class="laz-btn-primary hero-cta-toggle"
            aria-expanded="false"
            aria-controls="hero-cta-card"
          >
            Parler à un avocat
            <span class="laz-btn-arrow">→</span>
          </button>

          <div
            id="hero-cta-card"
            class="hero-cta-card"
            role="dialog"
            aria-hidden="true"
          >
            <button
              type="button"
              class="hero-cta-close"
              aria-label="Fermer"
            >
              ✕
            </button>
            <img
              src="/images/equipe.jpg"
              alt="Équipe Lazarègue Avocats"
              class="hero-cta-photo"
            />
            <img
              src="/images/logo.png"
              alt="Lazarègue Avocats"
              class="hero-cta-logo"
            />
            <div class="hero-cta-body">
              <a href="tel:0181706200" class="hero-cta-phone">
                01 81 70 62 00
              </a>
              <a
                href="mailto:contact@lazaregue-avocats.fr"
                class="hero-cta-email"
              >
                contact@lazaregue-avocats.fr
              </a>
              <p class="hero-cta-address">
                18 rue de Tilsitt, 75017 Paris
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="laz-hero-right">
    <slot name="hero-globe" />
  </div>
</section>

<style>
  .hero-cta-anchor {
    position: relative;
  }

  .hero-cta-card {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 50;
    width: 100%;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 0.75rem;
    background: #fff;
    opacity: 0;
    transform: translateY(16px);
    pointer-events: none;
    transition:
      opacity 0.3s ease,
      transform 0.3s ease;
  }

  .hero-cta-card.is-open {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  @media (min-width: 768px) {
    .hero-cta-card {
      position: absolute;
      bottom: 0;
      right: 0;
      left: auto;
      width: 300px;
    }
  }

  .hero-cta-close {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    z-index: 10;
    display: flex;
    width: 1.75rem;
    height: 1.75rem;
    align-items: center;
    justify-content: center;
    border: none;
    border-radius: 9999px;
    background: transparent;
    font-size: 0.875rem;
    color: rgba(10, 15, 46, 0.5);
    cursor: pointer;
    transition:
      color 0.15s ease,
      background-color 0.15s ease;
  }

  .hero-cta-close:hover {
    background: rgba(0, 0, 0, 0.05);
    color: #0a0f2e;
  }

  .hero-cta-photo {
    width: 100%;
    height: 160px;
    object-fit: cover;
    object-position: top;
  }

  .hero-cta-logo {
    height: 28px;
    width: auto;
    object-fit: contain;
    padding: 0.75rem 1rem;
  }

  .hero-cta-body {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    padding: 1rem;
    font-size: 0.875rem;
    color: #0a0f2e;
  }

  .hero-cta-phone {
    font-family: var(--ff-mono, ui-monospace, monospace);
    font-size: 12px;
    color: rgba(10, 15, 46, 0.7);
    text-decoration: none;
  }

  .hero-cta-phone:hover {
    color: #1a47ff;
  }

  .hero-cta-email {
    font-family: var(--ff-mono, ui-monospace, monospace);
    font-size: 11px;
    color: rgba(10, 15, 46, 0.6);
    text-decoration: none;
  }

  .hero-cta-email:hover {
    color: #1a47ff;
  }

  .hero-cta-address {
    margin: 0;
    font-size: 12px;
    color: rgba(10, 15, 46, 0.6);
  }
</style>

<script>
  function initHeroCtaPopup() {
    document.querySelectorAll(".hero-cta-anchor").forEach((anchor) => {
      const toggle = anchor.querySelector(".hero-cta-toggle");
      const card = anchor.querySelector(".hero-cta-card");
      const closeBtn = anchor.querySelector(".hero-cta-close");
      if (!toggle || !card) return;

      const setOpen = (open) => {
        card.classList.toggle("is-open", open);
        card.setAttribute("aria-hidden", open ? "false" : "true");
        toggle.setAttribute("aria-expanded", open ? "true" : "false");
      };

      toggle.addEventListener("click", () => {
        setOpen(!card.classList.contains("is-open"));
      });

      closeBtn?.addEventListener("click", () => setOpen(false));
    });
  }

  initHeroCtaPopup();
  document.addEventListener("astro:page-load", initHeroCtaPopup);
</script>
